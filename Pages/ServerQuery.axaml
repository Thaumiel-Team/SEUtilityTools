<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SEUtilityTools.Pages.ServerQuery"
        Title="SE Utility Tools"
        Width="1030"
        Height="650">

    <DockPanel>
        <WrapPanel x:Name="tabBar" DockPanel.Dock="Top" Orientation="Horizontal">
            <Button x:Name="HomeButton" Content="Home" Click="HomeButton_Click"/>
            <Button x:Name="BlueprintCalculatorButton" Content="Blueprint Calculator" Click="BlueprintCalculatorButton_Click"/>
            <Button x:Name="ServerQueryButton" Content="Server Query" Click="ServerQueryButton_Click"/>
        </WrapPanel>

        <!-- Content Area -->
        <Panel x:Name="contentArea">
            <!-- Page content goes here -->
        </Panel>
    </DockPanel>

</Window>